{{!-- Culture Tab --}}
<div class="tab {{tabs.culture.cssClass}}" data-tab="culture" data-group="a5e-mancer-tabs"
     role="tabpanel" id="culture-panel" aria-labelledby="tab-culture">
  <fieldset>
    <legend>{{localize 'am.app.culture.tooltip'}}</legend>
    <p>Culture represents how and where your character was raised — the traditions, values, and skills instilled during their upbringing. Unlike Heritage (biology), Culture (society) shapes who your character became through their environment.</p>
    <hr />

    <select id="culture-dropdown" name="culture" data-dtype="String"
      aria-required="true" aria-describedby="culture-description" style="display:none">
      <option value="">{{localize 'am.app.culture.select-placeholder'}}</option>
      {{#each cultureDocs}}
        {{#each this.docs}}
          <option value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]">{{this.name}}</option>
        {{/each}}
      {{/each}}
    </select>

    {{#if selectedItem}}
      {{!-- ── DETAIL VIEW ── --}}
      <div class="am-detail-view">
        <div class="am-detail-header">
          <img class="am-detail-img" src="{{selectedItem.img}}" alt="{{selectedItem.name}}">
          <div class="am-detail-meta">
            <div class="am-detail-name">{{selectedItem.name}}</div>
            <button type="button" class="am-change-btn" data-action="clearCardSelection" data-type="culture">
              <i class="fa-solid fa-rotate-left"></i> {{localize 'am.app.change-selection'}}
            </button>
          </div>
        </div>
        <div id="culture-description" class="am-description-panel overflow-vert-only"
             role="region" aria-live="polite" aria-atomic="true">{{{selectedItem.descriptionHtml}}}</div>
      </div>
    {{else}}
      {{!-- ── CARD BROWSER ── --}}
      <div class="am-card-browser">
        <div class="am-card-search-row">
          <input type="text" class="am-card-search form-input" data-for="culture"
            placeholder="{{localize 'am.app.culture.search-placeholder'}}"
            autocomplete="off" aria-label="Search culture">
          <button type="button" data-action="randomizeTabContent" data-for="culture"
            class="am-shuffle-btn" data-tooltip="{{localize 'am.app.randomize'}}">
            <i class="fa-solid fa-shuffle"></i>
          </button>
        </div>

        <div class="am-card-grid" data-type="culture" role="list">
          {{#each cultureDocs}}
            {{#each this.docs}}
              <button type="button" class="am-card" role="listitem"
                data-action="cardSelect"
                data-type="culture"
                data-value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]"
                data-name="{{this.name}}"
                data-tooltip="{{this.name}}">
                <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                <span class="am-card-name">{{this.name}}</span>
              </button>
            {{/each}}
          {{else}}
            <p class="am-hint">{{localize 'am.app.culture.none'}}</p>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </fieldset>
</div>
