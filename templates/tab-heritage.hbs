{{!-- Heritage Tab --}}
<div class="tab {{tabs.heritage.cssClass}}" data-tab="heritage" data-group="a5e-mancer-tabs"
     role="tabpanel" id="heritage-panel" aria-labelledby="tab-heritage">
  <fieldset>
    <legend>{{localize 'am.app.heritage.tooltip'}}</legend>
    <p>Your heritage represents your character's ancestry and innate traits — the biological and magical legacy passed down from their lineage. In A5e, Heritage replaces the concept of 'Race' and defines core physical traits, innate abilities, and natural features.</p>
    <hr />

    {{!-- Hidden select — drives DOMManager, progress bar, and review tab --}}
    <select id="heritage-dropdown" name="heritage" data-dtype="String"
      aria-required="true" aria-describedby="heritage-description" style="display:none">
      <option value="">{{localize 'am.app.heritage.select-placeholder'}}</option>
      {{#each heritageDocs}}
        {{#each this.docs}}
          <option value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]">{{this.name}}</option>
        {{/each}}
      {{/each}}
    </select>

    {{#if selectedItem}}
      {{!-- ── DETAIL VIEW ── --}}
      <div class="am-detail-view">
        <div class="am-detail-header">
          <img class="am-detail-img" src="{{selectedItem.img}}" alt="{{selectedItem.name}}">
          <div class="am-detail-meta">
            <div class="am-detail-name">{{selectedItem.name}}</div>
            <button type="button" class="am-change-btn" data-action="clearCardSelection" data-type="heritage">
              <i class="fa-solid fa-rotate-left"></i> {{localize 'am.app.change-selection'}}
            </button>
          </div>
        </div>
        <div id="heritage-description" class="am-description-panel overflow-vert-only"
             role="region" aria-live="polite" aria-atomic="true">{{{selectedItem.descriptionHtml}}}</div>
      </div>
    {{else}}
      {{!-- ── CARD BROWSER ── --}}
      <div class="am-card-browser">
        <div class="am-card-search-row">
          <input type="text" class="am-card-search form-input" data-for="heritage"
            placeholder="{{localize 'am.app.heritage.search-placeholder'}}"
            autocomplete="off" aria-label="Search heritage">
          <button type="button" data-action="randomizeTabContent" data-for="heritage"
            class="am-shuffle-btn" data-tooltip="{{localize 'am.app.randomize'}}">
            <i class="fa-solid fa-shuffle"></i>
          </button>
        </div>

        <div class="am-card-grid" data-type="heritage" role="list">
          {{#each heritageDocs}}
            {{#each this.docs}}
              <button type="button" class="am-card" role="listitem"
                data-action="cardSelect"
                data-type="heritage"
                data-value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]"
                data-name="{{this.name}}"
                data-tooltip="{{this.name}}">
                <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                <span class="am-card-name">{{this.name}}</span>
              </button>
            {{/each}}
          {{else}}
            <p class="am-hint">{{localize 'am.app.heritage.none'}}</p>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </fieldset>
</div>
