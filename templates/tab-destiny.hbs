{{!-- Destiny Tab --}}
<div class="tab {{tabs.destiny.cssClass}}" data-tab="destiny" data-group="a5e-mancer-tabs"
     role="tabpanel" id="destiny-panel" aria-labelledby="tab-destiny">
  <fieldset>
    <legend>{{localize 'am.app.destiny.tooltip'}}</legend>
    <p>Destiny is unique to A5e — it represents your character's long-term purpose and motivation. Each destiny grants a special feature, an inspiring source of motivation, and a fulfillment reward when major milestones are achieved.</p>
    <hr />

    <select id="destiny-dropdown" name="destiny" data-dtype="String"
      aria-required="true" aria-describedby="destiny-description" style="display:none">
      <option value="">{{localize 'am.app.destiny.select-placeholder'}}</option>
      {{#each destinyDocs}}
        {{#each this.docs}}
          <option value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]">{{this.name}}</option>
        {{/each}}
      {{/each}}
    </select>

    {{#if selectedItem}}
      {{!-- ── DETAIL VIEW ── --}}
      <div class="am-detail-view">
        <div class="am-detail-header">
          <img class="am-detail-img" src="{{selectedItem.img}}" alt="{{selectedItem.name}}">
          <div class="am-detail-meta">
            <div class="am-detail-name">{{selectedItem.name}}</div>
            <button type="button" class="am-change-btn" data-action="clearCardSelection" data-type="destiny">
              <i class="fa-solid fa-rotate-left"></i> {{localize 'am.app.change-selection'}}
            </button>
          </div>
        </div>
        <div id="destiny-description" class="am-description-panel overflow-vert-only"
             role="region" aria-live="polite" aria-atomic="true">{{{selectedItem.descriptionHtml}}}</div>
      </div>
    {{else}}
      {{!-- ── CARD BROWSER ── --}}
      <div class="am-card-browser">
        <div class="am-card-search-row">
          <input type="text" class="am-card-search form-input" data-for="destiny"
            placeholder="{{localize 'am.app.destiny.search-placeholder'}}"
            autocomplete="off" aria-label="Search destiny">
          <button type="button" data-action="randomizeTabContent" data-for="destiny"
            class="am-shuffle-btn" data-tooltip="{{localize 'am.app.randomize'}}">
            <i class="fa-solid fa-shuffle"></i>
          </button>
        </div>

        <div class="am-card-grid" data-type="destiny" role="list">
          {{#each destinyDocs}}
            {{#each this.docs}}
              <button type="button" class="am-card" role="listitem"
                data-action="cardSelect"
                data-type="destiny"
                data-value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]"
                data-name="{{this.name}}"
                data-tooltip="{{this.name}}">
                <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                <span class="am-card-name">{{this.name}}</span>
              </button>
            {{/each}}
          {{else}}
            <p class="am-hint">{{localize 'am.app.destiny.none'}}</p>
          {{/each}}
        </div>
      </div>
    {{/if}}
  </fieldset>
</div>
