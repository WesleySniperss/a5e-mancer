{{!-- A5e Mancer Sidebar Footer --}}
<footer>
  <div class="am-footer-container">

    {{!-- Submit / Create Character (last tab only) --}}
    {{#if isLastTab}}
      {{#if canCreateActor}}
        <button type="submit" data-action="submit" class="am-footer-submit am-sidebar-submit">
          <i class="fa-solid fa-wand-magic-sparkles"></i>
          <span>{{localize 'am.app.submit'}}</span>
        </button>
      {{/if}}
    {{/if}}

    {{!-- Prev / Next navigation --}}
    {{#if navigationButtons}}
      <div class="am-sidebar-nav-row">
        {{#unless isFirstTab}}
          <button type="button" data-action="previousTab" class="am-nav-prev"
            data-tooltip='{{previousTabName}}'>
            <i class="fas fa-chevron-left"></i>
          </button>
        {{/unless}}
        {{#unless isLastTab}}
          <button type="button" data-action="nextTab" class="am-nav-next"
            data-tooltip='{{nextTabName}}'>
            <i class="fas fa-chevron-right"></i>
          </button>
        {{/unless}}
      </div>
    {{/if}}

    {{!-- Utility actions: icon-only with tooltips --}}
    <div class="am-sidebar-util-row">
      {{#if randomizeButton}}
        <button type="button" data-action="randomize" class="am-footer-randomize"
          data-tooltip='{{localize "am.app.randomize"}}'>
          <i class="fa-solid fa-shuffle"></i>
        </button>
      {{/if}}

      <button type="submit" data-action="saveOptions" class="am-footer-save"
        data-tooltip='{{localize "am.app.save-description"}}'>
        <i class="fa-solid fa-floppy-disk"></i>
      </button>

      <button type="button" data-action="resetOptions" class="am-footer-reset"
        data-tooltip='{{localize "am.app.reset-description"}}'>
        <i class="fa-solid fa-rotate-left"></i>
      </button>

      {{!-- type MUST be "button": an invalid type is treated as "submit" and would
            run the creation form handler — Cancel could actually create the actor --}}
      <button type="button" data-action="nosubmit" class="am-app-footer-cancel"
        data-tooltip='{{localize "am.app.cancel-description"}}'>
        <i class="fa-solid fa-xmark"></i>
      </button>
    </div>

  </div>
</footer>
