{{!-- Start Tab --}}
<div class="tab {{tabs.start.cssClass}}" data-tab="start" data-group="a5e-mancer-tabs"
     role="tabpanel" id="start-panel" aria-labelledby="tab-start">
  <fieldset id="start">
    <legend>{{localize 'am.app.start.tooltip'}}</legend>

    <h2>{{localize 'am.app.start.preamble.title'}}</h2>
    {{{localize 'am.app.start.preamble.text'}}}
    <hr />

    {{!-- Character Name --}}
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="character-name" class="label-15">{{localize 'am.app.start.name-label'}}</label>
      <input id="character-name" type="text" name="character-name"
        class="form-input input-35"
        placeholder="{{localize 'am.app.start.name-placeholder'}}"
        aria-required="true" />
      <button type="button" data-action="randomizeCharacterName" class="select-button button-7"
        data-tooltip="{{localize 'am.app.start.generate-random-name'}}">
        <i class="fa-solid fa-shuffle"></i>
      </button>
    </div>

    {{!-- GM: assign to player --}}
    {{#if isGM}}
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="player-assignment" class="label-15">{{localize 'am.app.start.player-label'}}</label>
      <select id="player-assignment" name="player" class="form-select input-35">
        <option value="">{{localize 'am.app.start.player-placeholder'}}</option>
        {{#each players}}
          <option value="{{this.id}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    {{/if}}

    {{!-- Character Art --}}
    <div class="art-selection-row flex items-center gap-sm mb-sm">
      <label for="character-art-path" class="label-15">{{localize 'am.app.start.character-art-label'}}</label>
      <input id="character-art-path" type="text" name="character-art"
        class="art-input input-35 form-input" readonly
        placeholder="{{localize 'am.app.start.character-art-placeholder'}}" />
      <button type="button" data-action="selectCharacterArt" class="select-button button-7">
        {{localize 'am.app.start.select-art'}}
      </button>
      <label class="checkbox-label flex items-center gap-xs">
        <input type="checkbox" id="link-token-art" checked />
        <span>{{localize 'am.app.start.token-same-as-character'}}</span>
      </label>
    </div>

    <div class="art-selection-row flex items-center gap-sm mb-sm" id="token-art-row" style="display:none">
      <label for="token-art-path" class="label-15">{{localize 'am.app.start.token-art-label'}}</label>
      <input id="token-art-path" type="text" name="token-art"
        class="art-input input-35 form-input" readonly />
      <button type="button" data-action="selectTokenArt" class="select-button button-7">
        {{localize 'am.app.start.select-art'}}
      </button>
    </div>

    {{!-- Player customization --}}
    {{#if playerCustomizationEnabled}}
    <hr />
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="player-color" class="label-15">{{localize 'am.app.start.player-color'}}</label>
      <color-picker id="player-color" name="player-color" class="input-35" value="#FF0000" />
    </div>
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="player-pronouns" class="label-15">{{localize 'am.app.start.player-pronouns'}}</label>
      <input id="player-pronouns" type="text" name="player-pronouns" class="form-input input-35"
        placeholder="{{localize 'am.app.start.player-pronouns-placeholder'}}" />
    </div>
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="player-avatar-path" class="label-15">{{localize 'am.app.start.player-avatar'}}</label>
      <input id="player-avatar-path" type="text" name="player-avatar"
        class="art-input input-35 form-input" readonly />
      <button type="button" data-action="selectPlayerAvatar" class="select-button button-7">
        {{localize 'am.app.start.select-art'}}
      </button>
    </div>
    {{/if}}

  </fieldset>
</div>
