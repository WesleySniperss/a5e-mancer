{{!-- Maneuvers Tab (character creation) --}}
<div class="tab {{tabs.maneuvers.cssClass}}" data-tab="maneuvers" data-group="a5e-mancer-tabs"
     role="tabpanel" id="maneuvers-panel" aria-labelledby="tab-maneuvers">
  <fieldset>
    <legend>{{localize 'am.app.maneuvers.tooltip'}}</legend>

    {{#if classSelected}}

      {{#if maneuverInfo}}

        <p>{{localize 'am.app.maneuvers.preamble'}}</p>

        <div class="am-maneuver-summary-box">
          <div class="am-info-row">
            <i class="fa-solid fa-chess-rook" style="color:var(--am-gold)"></i>
            <span>
              <strong>{{maneuverInfo.maneuversKnown}}</strong>
              {{localize 'am.app.maneuvers.known-at-1'}}
              ({{localize 'am.app.maneuvers.max-degree' degree=maneuverInfo.maxDegree}})
            </span>
          </div>
          <div class="am-info-row">
            <i class="fa-solid fa-bolt" style="color:var(--am-gold)"></i>
            <span>{{localize 'am.app.maneuvers.exertion-info'}}</span>
          </div>
          <div class="am-info-row">
            <i class="fa-solid fa-book"></i>
            <span>{{localize 'am.app.maneuvers.traditions-needed' n=maneuverInfo.traditions}}</span>
          </div>
        </div>

        <hr />

        {{!-- Selection counters --}}
        <div class="am-selection-header">
          <div class="am-counter-badge {{#if (gte selectedManeuverUuids.length maneuverInfo.maneuversKnown)}}am-badge-success{{else}}am-badge-pending{{/if}}">
            <i class="fa-solid fa-swords"></i>
            {{selectedManeuverUuids.length}}/{{maneuverInfo.maneuversKnown}}
          </div>
          {{#if selectedTraditions.length}}
            <div class="am-counter-badge am-badge-info">
              <i class="fa-solid fa-book"></i>
              {{selectedTraditions.length}}/{{maneuverInfo.traditions}} {{localize 'am.app.maneuvers.traditions-label'}}
            </div>
          {{/if}}
        </div>

        {{#if maneuversLoaded}}

          {{!-- Tradition filter pills --}}
          <div class="am-filter-pills" role="toolbar" aria-label="Filter by tradition">
            {{#each inlineTraditions}}
              <button type="button"
                      class="am-filter-pill {{#if this.active}}am-pill-active{{/if}} {{#if this.used}}am-pill-used{{/if}}"
                      data-action="filterManeuverTradition"
                      data-tradition="{{this.key}}"
                      data-tooltip="{{this.label}}">
                {{this.label}}
                {{#if this.used}}<i class="fa-solid fa-check am-pill-check"></i>{{/if}}
              </button>
            {{else}}
              <p class="am-hint">{{localize 'am.app.maneuvers.no-traditions'}}</p>
            {{/each}}
          </div>

          {{#if maneuverFilterTradition}}
            {{!-- Maneuver cards for selected tradition --}}
            {{#if visibleManeuvers.length}}
              <div class="am-card-grid am-inline-card-grid" data-type="maneuver-inline" role="list">
                {{#each visibleManeuvers}}
                  <button type="button"
                          class="am-card {{#if this.isSelected}}am-card-selected{{/if}}"
                          role="listitem"
                          data-action="toggleManeuver"
                          data-uuid="{{this.uuid}}"
                          data-tradition="{{this.tradition}}"
                          data-name="{{this.name}}"
                          data-tooltip="{{this.name}}">
                    <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                    <span class="am-card-name">{{this.name}}</span>
                    <div class="am-card-meta">
                      <span class="am-degree-pip">{{this.degree}}°</span>
                      {{#if this.exertion}}
                        <span class="am-ex-cost"><i class="fa-solid fa-bolt"></i>{{this.exertion}}</span>
                      {{/if}}
                    </div>
                  </button>
                {{/each}}
              </div>
            {{else}}
              <p class="am-hint">{{localize 'am.maneuvers.none-found'}}</p>
            {{/if}}
            <div class="am-inline-description overflow-vert-only">
              <p class="am-hint am-inline-desc-hint">{{localize 'am.app.hover-for-description'}}</p>
            </div>
          {{else}}
            <p class="am-hint am-filter-prompt">
              <i class="fa-solid fa-hand-pointer"></i>
              {{localize 'am.app.maneuvers.select-tradition-hint'}}
            </p>
          {{/if}}

        {{else}}
          <p class="am-loading"><i class="fas fa-spinner fa-spin"></i> {{localize 'am.app.loading'}}</p>
        {{/if}}

        {{!-- Hidden inputs for form submission --}}
        {{#each selectedManeuverUuids}}
          <input type="hidden" name="maneuverUuids[]" value="{{this}}" />
        {{/each}}
        {{#each selectedTraditions}}
          <input type="hidden" name="maneuverTraditions[]" value="{{this}}" />
        {{/each}}

      {{else}}

        {{!-- Class has no maneuvers at level 1 --}}
        <div class="am-info-placeholder">
          <i class="fa-solid fa-circle-info fa-2x" style="opacity:0.5"></i>
          {{#if isManeuverClass}}
            <p>{{localize 'am.app.maneuvers.class-maneuvers-later'}}</p>
            <p class="am-hint">{{localize 'am.app.maneuvers.class-maneuvers-later-hint'}}</p>
          {{else}}
            <p>{{localize 'am.app.maneuvers.class-no-maneuvers'}}</p>
            <p class="am-hint">{{localize 'am.app.maneuvers.class-no-maneuvers-hint'}}</p>
          {{/if}}
        </div>

      {{/if}}

    {{else}}

      <div class="am-info-placeholder">
        <i class="fa-solid fa-arrow-left fa-xl" style="opacity:0.4"></i>
        <p>{{localize 'am.app.maneuvers.select-class-first'}}</p>
      </div>

    {{/if}}

  </fieldset>
</div>
