{{!-- Background Tab --}}
<div class="tab {{tabs.background.cssClass}}" data-tab="background" data-group="a5e-mancer-tabs"
     role="tabpanel" id="background-panel" aria-labelledby="tab-background">
  <fieldset>
    <legend>{{localize 'am.app.background.tooltip'}}</legend>
    <p>Your background describes your character's life before adventuring — their occupation, social standing, and the experiences that shaped their skills and outlook. Choose a background that fits your character's pre-adventure story.</p>
    <hr />

    {{!-- Dropdown --}}
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="background-dropdown">{{localize 'am.app.background.select-label'}}</label>
      <select id="background-dropdown" name="background" class="form-select" data-dtype="String"
        aria-required="true" aria-describedby="background-description">
        <option value="">{{localize 'am.app.background.select-placeholder'}}</option>

        {{#each backgroundDocs}}
          {{#if this.folderName}}
            <optgroup label="{{this.folderName}}">
              {{#each this.docs}}
                <option value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]">
                  {{this.name}}
                </option>
              {{/each}}
            </optgroup>
          {{else}}
            {{#each this.docs}}
              <option value="{{this.id}} ({{this.packId}}) [{{this.uuid}}]">
                {{this.name}}
              </option>
            {{/each}}
          {{/if}}
        {{else}}
          <option>{{localize 'am.app.background.none'}}</option>
        {{/each}}
      </select>
      <button type="button" data-action="randomizeTabContent" data-for="background"
        class="select-button" data-tooltip="{{localize 'am.app.randomize'}}">
        <i class="fa-solid fa-shuffle"></i>
      </button>
    </div>

    {{!-- Description panel --}}
    <div id="background-description" class="am-description-panel overflow-vert-only"
         role="region" aria-live="polite" aria-atomic="true">
    </div>
  </fieldset>
</div>
