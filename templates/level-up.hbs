{{!-- Level Up Dialog --}}
<div class="am-levelup-content">

  {{!-- Mode Toggle --}}
  <section class="lu-section lu-mode-section">
    <div class="lu-mode-toggle">
      <button type="button" class="lu-mode-btn {{#if (eq mode 'levelup')}}lu-mode-active{{/if}}" data-mode="levelup">
        <i class="fa-solid fa-arrow-up"></i>
        {{localize 'am.levelup.mode-levelup'}}
      </button>
      <button type="button" class="lu-mode-btn {{#if (eq mode 'multiclass')}}lu-mode-active{{/if}}" data-mode="multiclass">
        <i class="fa-solid fa-code-branch"></i>
        {{localize 'am.levelup.mode-multiclass'}}
      </button>
    </div>
  </section>

  <hr />

  {{!-- ═══════════════════════════════════════════════════════ MULTICLASS MODE --}}
  {{#if (eq mode 'multiclass')}}

  <section class="lu-section">
    <h3><i class="fa-solid fa-code-branch"></i> {{localize 'am.levelup.multiclass-title'}}</h3>
    <p class="am-hint">{{localize 'am.levelup.multiclass-hint'}}</p>

    {{#if availableClasses.length}}
      <div class="form-row flex items-center gap-sm mb-sm">
        <label for="lu-new-class-select">{{localize 'am.levelup.multiclass-class-label'}}</label>
        <select id="lu-new-class-select" name="newClassUuid" class="form-select">
          <option value="">{{localize 'am.levelup.multiclass-class-placeholder'}}</option>
          {{#each availableClasses}}
            <option value="{{this.uuid}}" {{#if (eq this.uuid ../newClass.uuid)}}selected{{/if}}>
              {{this.name}} (d{{this.hitDie}}){{#unless this.prereqs.meets}} ✗{{/unless}}
            </option>
          {{/each}}
        </select>
      </div>

      {{#if newClass}}
        {{#if newClass.prereqs.meets}}
          <p class="lu-prereq lu-prereq-ok">
            <i class="fa-solid fa-circle-check"></i>
            {{localize 'am.levelup.multiclass-prereqs-ok'}}
          </p>
        {{else}}
          <p class="lu-prereq lu-prereq-fail">
            <i class="fa-solid fa-triangle-exclamation"></i>
            {{localize 'am.levelup.multiclass-prereqs-fail'}}: <strong>{{newClass.prereqs.missingText}}</strong>
          </p>
        {{/if}}
      {{/if}}
    {{else}}
      <p class="am-hint"><i class="fa-solid fa-circle-info"></i> {{localize 'am.levelup.multiclass-none-available'}}</p>
    {{/if}}

    <div class="lu-level-badge flex items-center gap-sm">
      <span class="lu-badge">
        {{localize 'am.levelup.total-level'}}: {{newTotalLevel}}
      </span>
    </div>
  </section>

  {{#if newClass}}
  <hr />

  {{!-- HP section --}}
  <section class="lu-section">
    <h3><i class="fa-solid fa-heart"></i> {{localize 'am.levelup.hp-title'}} (d{{newClass.hitDie}})</h3>
    <p class="am-hint">{{localize 'am.levelup.con-mod'}}: {{#if (gte conMod 0)}}+{{/if}}{{conMod}}</p>

    <div class="lu-hp-methods">
      <label class="lu-hp-method {{#if (eq hpMethod 'average')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="average" {{#if (eq hpMethod 'average')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-average'}}</span>
          <span class="lu-method-value">{{avgHP}} HP</span>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'roll')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="roll" {{#if (eq hpMethod 'roll')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-roll'}}</span>
          <div class="flex items-center gap-sm">
            <button type="button" data-action="rollHP" class="lu-roll-btn">
              <i class="fa-solid fa-dice-d{{newClass.hitDie}}"></i>
              {{localize 'am.levelup.roll'}}
            </button>
            <span id="lu-roll-result" class="lu-roll-result">
              {{#if rolledHP}}{{rolledHP}} HP{{else}}—{{/if}}
            </span>
          </div>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'max')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="max" {{#if (eq hpMethod 'max')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-max'}}</span>
          <span class="lu-method-value">{{newClass.hitDie}} + {{conMod}} CON HP</span>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'manual')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="manual" {{#if (eq hpMethod 'manual')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-manual'}}</span>
          <input id="lu-manual-hp" type="number" name="manualHP"
            class="form-input lu-manual-input" min="1" placeholder="?"
            {{#unless (eq hpMethod 'manual')}}disabled{{/unless}} />
        </div>
      </label>
    </div>
  </section>

  {{!-- Maneuvers (multiclass) --}}
  {{#if maneuverInfo.newManeuversToLearn}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-swords"></i> {{localize 'am.maneuvers.section-title'}}</h3>
    {{#if maneuverInfo.degreeUnlocked}}
      <p class="am-hint">
        <i class="fa-solid fa-arrow-up" style="color:var(--am-gold)"></i>
        {{localize 'am.maneuvers.degree-unlocked' degree=maneuverInfo.degreeUnlocked}}
      </p>
    {{/if}}
    <p>{{localize 'am.maneuvers.pick-prompt' n=maneuverInfo.newManeuversToLearn}}
      <strong>({{localize 'am.maneuvers.max-degree' degree=maneuverInfo.maxDegree}})</strong>
    </p>

    <div class="am-selection-header">
      <div class="am-counter-badge {{#if (gte selectedManeuverCount maneuverInfo.newManeuversToLearn)}}am-badge-success{{else}}am-badge-pending{{/if}}">
        <i class="fa-solid fa-swords"></i>
        {{selectedManeuverCount}}/{{maneuverInfo.newManeuversToLearn}}
      </div>
    </div>

    {{#if maneuversLoaded}}
      <div class="am-filter-pills" role="toolbar">
        {{#each inlineTraditions}}
          <button type="button"
                  class="am-filter-pill {{#if this.active}}am-pill-active{{/if}} {{#if this.used}}am-pill-used{{/if}}"
                  data-action="luFilterManeuverTradition"
                  data-tradition="{{this.key}}">
            {{this.label}}
            {{#if this.used}}<i class="fa-solid fa-check am-pill-check"></i>{{/if}}
          </button>
        {{else}}
          <p class="am-hint">{{localize 'am.app.maneuvers.no-traditions'}}</p>
        {{/each}}
      </div>
      {{#if maneuverFilterTradition}}
        {{#if visibleManeuvers.length}}
          <div class="am-card-grid am-inline-card-grid" role="list">
            {{#each visibleManeuvers}}
              <button type="button"
                      class="am-card {{#if this.isSelected}}am-card-selected{{/if}}"
                      role="listitem"
                      data-action="luToggleManeuver"
                      data-uuid="{{this.uuid}}"
                      data-tradition="{{this.tradition}}"
                      data-name="{{this.name}}">
                <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                <span class="am-card-name">{{this.name}}</span>
                <div class="am-card-meta">
                  <span class="am-degree-pip">{{this.degree}}°</span>
                  {{#if this.exertion}}
                    <span class="am-ex-cost"><i class="fa-solid fa-bolt"></i>{{this.exertion}}</span>
                  {{/if}}
                </div>
              </button>
            {{/each}}
          </div>
        {{else}}
          <p class="am-hint">{{localize 'am.maneuvers.none-found'}}</p>
        {{/if}}
        <div class="am-inline-description overflow-vert-only">
          <p class="am-hint am-inline-desc-hint">{{localize 'am.app.hover-for-description'}}</p>
        </div>
      {{else}}
        <p class="am-hint am-filter-prompt">
          <i class="fa-solid fa-hand-pointer"></i>
          {{localize 'am.app.maneuvers.select-tradition-hint'}}
        </p>
      {{/if}}
    {{else}}
      <p class="am-loading"><i class="fas fa-spinner fa-spin"></i> {{localize 'am.app.loading'}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- Spells (multiclass) --}}
  {{#if spellInfo}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-sparkles"></i> {{localize 'am.levelup.spells-title'}}</h3>
    <p class="am-hint">{{localize 'am.levelup.spells-hint'}}</p>

    <div class="am-selection-header">
      {{#if spellInfo.cantrips}}
        <div class="am-counter-badge {{#if (gte selectedCantripCount spellInfo.cantrips)}}am-badge-success{{else}}am-badge-pending{{/if}}">
          <i class="fa-solid fa-sparkles"></i>
          {{localize 'am.app.spells.cantrips'}}: {{selectedCantripCount}}/{{spellInfo.cantrips}}
        </div>
      {{/if}}
      {{#if (eq spellInfo.type 'known')}}
        <div class="am-counter-badge {{#if (gte selectedSpellCount spellInfo.spellsKnown)}}am-badge-success{{else}}am-badge-pending{{/if}}">
          <i class="fa-solid fa-book-sparkles"></i>
          {{localize 'am.app.spells.spells-label'}}: {{selectedSpellCount}}/{{spellInfo.spellsKnown}}
        </div>
      {{/if}}
    </div>

    {{#if spellsLoaded}}
      {{#if spellLevelPills.length}}
        <div class="am-filter-pills" role="toolbar">
          <button type="button"
                  class="am-filter-pill {{#if spellLevelAllActive}}am-pill-active{{/if}}"
                  data-action="luFilterSpellLevel" data-level="">
            {{localize 'am.app.spells.filter-all'}}
          </button>
          {{#each spellLevelPills}}
            <button type="button"
                    class="am-filter-pill {{#if this.active}}am-pill-active{{/if}}"
                    data-action="luFilterSpellLevel"
                    data-level="{{this.level}}">
              {{this.label}}
            </button>
          {{/each}}
        </div>
      {{/if}}
      {{#if spellSchoolPills.length}}
        <div class="am-filter-pills am-filter-pills-sm" role="toolbar">
          <button type="button"
                  class="am-filter-pill {{#if spellSchoolAllActive}}am-pill-active{{/if}}"
                  data-action="luFilterSpellSchool" data-school="">
            {{localize 'am.app.spells.filter-all-schools'}}
          </button>
          {{#each spellSchoolPills}}
            <button type="button"
                    class="am-filter-pill {{#if this.active}}am-pill-active{{/if}}"
                    data-action="luFilterSpellSchool"
                    data-school="{{this.key}}">
              {{this.label}}
            </button>
          {{/each}}
        </div>
      {{/if}}
      {{#if visibleSpells.length}}
        <div class="am-card-grid am-inline-card-grid am-spell-inline-grid" role="list">
          {{#each visibleSpells}}
            <button type="button"
                    class="am-card {{#if this.isSelected}}am-card-selected am-card-selected-spell{{/if}}"
                    role="listitem"
                    data-action="luToggleSpell"
                    data-uuid="{{this.uuid}}"
                    data-level="{{this.level}}"
                    data-name="{{this.name}}">
              <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
              <span class="am-card-name">{{this.name}}</span>
              <div class="am-card-meta">
                {{#if this.isCantrip}}
                  <span class="am-level-pip am-cantrip-pip">C</span>
                {{else}}
                  <span class="am-level-pip">{{this.level}}</span>
                {{/if}}
                {{#if this.concentration}}
                  <span class="am-conc-tag" title="Concentration">C</span>
                {{/if}}
              </div>
            </button>
          {{/each}}
        </div>
      {{else}}
        <p class="am-hint">{{localize 'am.spells.none-found'}}</p>
      {{/if}}
      <div class="am-inline-description overflow-vert-only">
        <p class="am-hint am-inline-desc-hint">{{localize 'am.app.hover-for-description'}}</p>
      </div>
    {{else}}
      <p class="am-loading"><i class="fas fa-spinner fa-spin"></i> {{localize 'am.app.loading'}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{!-- Exploration Knack (multiclass, based on new total level) --}}
  {{#if info.gainsKnack}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-compass"></i> {{knackLabel}}</h3>
    <p class="am-hint">{{localize 'am.levelup.knack-hint'}}</p>
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="lu-knack-select">{{knackLabel}}</label>
      <select id="lu-knack-select" name="knackUuid" class="form-select">
        <option value="">{{localize 'am.levelup.knack-placeholder'}}</option>
        {{#each knacks}}
          <option value="{{this.uuid}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div id="lu-knack-description" class="lu-item-description am-description-panel overflow-vert-only"></div>
  </section>
  {{/if}}

  {{/if}}{{!-- /newClass --}}

  {{!-- ═══════════════════════════════════════════════════ LEVEL-UP MODE --}}
  {{else}}

  {{!-- Class selector --}}
  <section class="lu-section">
    <h3><i class="fa-solid fa-chess-rook"></i> {{localize 'am.levelup.choose-class'}}</h3>

    {{#if (gt classes.length 1)}}
      <div class="form-row flex items-center gap-sm mb-sm">
        <label for="lu-class-select">{{localize 'am.levelup.class-label'}}</label>
        <select id="lu-class-select" name="classId" class="form-select">
          {{#each classes}}
            <option value="{{this.id}}" {{#if (eq this.id ../selectedClass.id)}}selected{{/if}}>
              {{this.name}} ({{localize 'am.levelup.level'}} {{this.level}})
            </option>
          {{/each}}
        </select>
      </div>
    {{else}}
      <p>
        <strong>{{selectedClass.name}}</strong>
        {{localize 'am.levelup.current-level'}}: {{selectedClass.level}}
        → <strong>{{newClassLevel}}</strong>
      </p>
    {{/if}}

    <div class="lu-level-badge flex items-center gap-sm">
      <span class="lu-badge">
        {{localize 'am.levelup.total-level'}}: {{newTotalLevel}}
      </span>
      {{#if info.gainsASI}}
        <span class="lu-badge lu-badge-gold">
          <i class="fa-solid fa-star"></i> {{localize 'am.levelup.gains-asi'}}
        </span>
      {{/if}}
      {{#if info.gainsKnack}}
        <span class="lu-badge lu-badge-blue">
          <i class="fa-solid fa-compass"></i> {{localize 'am.levelup.gains-knack'}}
        </span>
      {{/if}}
    </div>
  </section>

  <hr />

  {{!-- HP section --}}
  <section class="lu-section">
    <h3><i class="fa-solid fa-heart"></i> {{localize 'am.levelup.hp-title'}} (d{{selectedClass.hitDie}})</h3>
    <p class="am-hint">{{localize 'am.levelup.con-mod'}}: {{#if (gte conMod 0)}}+{{/if}}{{conMod}}</p>

    <div class="lu-hp-methods">
      <label class="lu-hp-method {{#if (eq hpMethod 'average')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="average" {{#if (eq hpMethod 'average')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-average'}}</span>
          <span class="lu-method-value">{{avgHP}} HP</span>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'roll')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="roll" {{#if (eq hpMethod 'roll')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-roll'}}</span>
          <div class="flex items-center gap-sm">
            <button type="button" data-action="rollHP" class="lu-roll-btn">
              <i class="fa-solid fa-dice-d{{selectedClass.hitDie}}"></i>
              {{localize 'am.levelup.roll'}}
            </button>
            <span id="lu-roll-result" class="lu-roll-result">
              {{#if rolledHP}}{{rolledHP}} HP{{else}}—{{/if}}
            </span>
          </div>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'max')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="max" {{#if (eq hpMethod 'max')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-max'}}</span>
          <span class="lu-method-value">{{selectedClass.hitDie}} + {{conMod}} CON HP</span>
        </div>
      </label>
      <label class="lu-hp-method {{#if (eq hpMethod 'manual')}}lu-selected{{/if}}">
        <input type="radio" name="hp-method" value="manual" {{#if (eq hpMethod 'manual')}}checked{{/if}} />
        <div class="lu-method-content">
          <span class="lu-method-title">{{localize 'am.levelup.hp-manual'}}</span>
          <input id="lu-manual-hp" type="number" name="manualHP"
            class="form-input lu-manual-input" min="1" placeholder="?"
            {{#unless (eq hpMethod 'manual')}}disabled{{/unless}} />
        </div>
      </label>
    </div>
  </section>

  {{!-- ASI / Feat --}}
  {{#if info.gainsASI}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-star"></i> {{localize 'am.levelup.asi-title'}}</h3>
    <p class="am-hint">{{localize 'am.levelup.asi-hint'}}</p>
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="lu-feat-select">{{localize 'am.levelup.feat-label'}}</label>
      <select id="lu-feat-select" name="featUuid" class="form-select">
        <option value="">{{localize 'am.levelup.feat-placeholder'}}</option>
        {{#each feats}}
          <option value="{{this.uuid}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <p class="lu-system-note">
      <i class="fa-solid fa-up-right-from-square"></i>
      {{localize 'am.levelup.system-window-note'}}
    </p>
    <div id="lu-feat-description" class="lu-item-description am-description-panel overflow-vert-only"></div>
    <p class="am-hint">{{localize 'am.levelup.asi-note'}}</p>
  </section>
  {{/if}}

  {{!-- Exploration Knack --}}
  {{#if info.gainsKnack}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-compass"></i> {{knackLabel}}</h3>
    <p class="am-hint">{{localize 'am.levelup.knack-hint'}}</p>
    <div class="form-row flex items-center gap-sm mb-sm">
      <label for="lu-knack-select">{{knackLabel}}</label>
      <select id="lu-knack-select" name="knackUuid" class="form-select">
        <option value="">{{localize 'am.levelup.knack-placeholder'}}</option>
        {{#each knacks}}
          <option value="{{this.uuid}}">{{this.name}}</option>
        {{/each}}
      </select>
    </div>
    <div id="lu-knack-description" class="lu-item-description am-description-panel overflow-vert-only"></div>
  </section>
  {{/if}}

  {{!-- Maneuvers (level-up mode) --}}
  {{#if maneuverInfo.newManeuversToLearn}}
  <hr />
  <section class="lu-section">
    <h3><i class="fa-solid fa-swords"></i> {{localize 'am.maneuvers.section-title'}}</h3>
    {{#if maneuverInfo.degreeUnlocked}}
      <p class="am-hint">
        <i class="fa-solid fa-arrow-up" style="color:var(--am-gold)"></i>
        {{localize 'am.maneuvers.degree-unlocked' degree=maneuverInfo.degreeUnlocked}}
      </p>
    {{/if}}
    <p>{{localize 'am.maneuvers.pick-prompt' n=maneuverInfo.newManeuversToLearn}}
      <strong>({{localize 'am.maneuvers.max-degree' degree=maneuverInfo.maxDegree}})</strong>
    </p>

    <div class="am-selection-header">
      <div class="am-counter-badge {{#if (gte selectedManeuverCount maneuverInfo.newManeuversToLearn)}}am-badge-success{{else}}am-badge-pending{{/if}}">
        <i class="fa-solid fa-swords"></i>
        {{selectedManeuverCount}}/{{maneuverInfo.newManeuversToLearn}}
      </div>
      {{#if selectedTraditions.length}}
        <div class="am-counter-badge am-badge-info">
          <i class="fa-solid fa-book"></i>
          {{selectedTraditions.length}} {{localize 'am.app.maneuvers.traditions-label'}}
        </div>
      {{/if}}
    </div>

    {{#if maneuversLoaded}}
      <div class="am-filter-pills" role="toolbar">
        {{#each inlineTraditions}}
          <button type="button"
                  class="am-filter-pill {{#if this.active}}am-pill-active{{/if}} {{#if this.used}}am-pill-used{{/if}}"
                  data-action="luFilterManeuverTradition"
                  data-tradition="{{this.key}}">
            {{this.label}}
            {{#if this.used}}<i class="fa-solid fa-check am-pill-check"></i>{{/if}}
          </button>
        {{else}}
          <p class="am-hint">{{localize 'am.app.maneuvers.no-traditions'}}</p>
        {{/each}}
      </div>
      {{#if maneuverFilterTradition}}
        {{#if visibleManeuvers.length}}
          <div class="am-card-grid am-inline-card-grid" role="list">
            {{#each visibleManeuvers}}
              <button type="button"
                      class="am-card {{#if this.isSelected}}am-card-selected{{/if}}"
                      role="listitem"
                      data-action="luToggleManeuver"
                      data-uuid="{{this.uuid}}"
                      data-tradition="{{this.tradition}}"
                      data-name="{{this.name}}">
                <img class="am-card-img" src="{{this.img}}" alt="" loading="lazy">
                <span class="am-card-name">{{this.name}}</span>
                <div class="am-card-meta">
                  <span class="am-degree-pip">{{this.degree}}°</span>
                  {{#if this.exertion}}
                    <span class="am-ex-cost"><i class="fa-solid fa-bolt"></i>{{this.exertion}}</span>
                  {{/if}}
                </div>
              </button>
            {{/each}}
          </div>
        {{else}}
          <p class="am-hint">{{localize 'am.maneuvers.none-found'}}</p>
        {{/if}}
        <div class="am-inline-description overflow-vert-only">
          <p class="am-hint am-inline-desc-hint">{{localize 'am.app.hover-for-description'}}</p>
        </div>
      {{else}}
        <p class="am-hint am-filter-prompt">
          <i class="fa-solid fa-hand-pointer"></i>
          {{localize 'am.app.maneuvers.select-tradition-hint'}}
        </p>
      {{/if}}
    {{else}}
      <p class="am-loading"><i class="fas fa-spinner fa-spin"></i> {{localize 'am.app.loading'}}</p>
    {{/if}}
  </section>
  {{/if}}

  {{/if}}{{!-- /mode toggle --}}

  <hr />

  {{!-- Footer --}}
  <div class="lu-footer flex justify-between items-center">
    <button type="cancel" class="lu-cancel" onclick="this.closest('.application')._element?.[0]?.dispatchEvent(new Event('close'))">
      {{localize 'am.app.cancel'}}
    </button>
    <button type="submit" data-action="submit" class="am-footer-submit lu-submit">
      {{#if (eq mode 'multiclass')}}
